# Escape literal `$` characters as `$$` when using Docker Compose env files.

# Required ClickUp API access
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLICKUP_TEAM_ID=123456

# Required MCP client auth
CLICKUP_MCP_API_KEY=change-me

# Optional generic aliases
# MCP_API_KEY=change-me
# MCP_API_KEYS=key-one,key-two

# Optional endpoint overrides
# CLICKUP_MCP_PORT=3004
# CLICKUP_MCP_HOST_PORT=3004
# CLICKUP_MCP_PATH=/mcp

# Optional write controls
# WRITE_MODE=selective
# WRITE_ALLOWED_SPACES=12345,67890
# WRITE_ALLOWED_LISTS=111,222

# Optional runtime tuning
# CHAR_LIMIT=16000
# MAX_ATTACHMENT_MB=8
# REPORTING_MAX_TASKS=200
# DEFAULT_RISK_WINDOW_DAYS=5
# API_KEY_MODE=disabled
